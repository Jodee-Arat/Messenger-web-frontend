  "overview": {
    "subtitle": "A messenger with optional end-to-end encryption based on Russian GOST cryptographic standards, digital signatures, and real-time communication.",
    "features": {
      "e2ee": {
        "title": "Secret Chats",
        "desc": "Optional end-to-end encryption — create a secret chat and messages are encrypted on the device. Only participants can read them, the server never sees plaintext."
      },
      "gost": {
        "title": "GOST Cryptography",
        "desc": "Uses GOST R 34.10 (signatures), GOST R 34.11 Streebog (hashing), and GOST R 34.12 Kuznechik (encryption)."
      },
      "realtime": {
        "title": "Real-Time Messaging",
        "desc": "Instant message delivery via GraphQL subscriptions — no polling, no delays."
      },
      "groups": {
        "title": "Groups & Direct Messages",
        "desc": "Regular and secret group chats or private 1-on-1 conversations — choose the level of privacy you need."
      },
      "modern": {
        "title": "Modern Stack",
        "desc": "Built with React, Next.js, NestJS, GraphQL, PostgreSQL, and Redis for reliability and speed."
      },
      "open": {
        "title": "Cross-Platform",
        "desc": "Available as a web app and a mobile app (React Native / Expo) with shared cryptographic core."
      }
    },
    "techTitle": "Technology Stack",
    "tech": {
      "frontend": "Frontend",
      "backend": "Backend",
      "mobile": "Mobile",
      "crypto": "Cryptography"
    }
  },
